{
  "compilerOptions": {
    "sourceMap": true,
    "target": "esnext",
    "module": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strict": false,
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src/templates/ts/*", "bin/**/*"]
}
